generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Usuario {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  username     String   @unique @db.VarChar(255)
  nome         String?  @db.VarChar(50)
  fotoPerfil   String?  @db.VarChar(255)
  email        String?  @db.VarChar(255)
  senha        String?  @db.VarChar(80)
  tipo         String?  @db.VarChar(45)
  bio          String?  @db.VarChar(255)
  local        String?  @db.VarChar(50)
  dataCadastro DateTime @default(now()) @db.Timestamp(0)

  publicacoes Publicacao[]
  curtidas    Curtir[]
  comentarios Comentario[]
  seguindo    Seguir[]     @relation("Seguidor")
  seguidores  Seguir[]     @relation("Seguido")
}

model Publicacao {
  id             Int      @id @default(autoincrement()) @db.UnsignedInt
  resumo         String?  @db.VarChar(255)
  slug           String?  @db.VarChar(255)
  conteudo       String?  @db.Text
  fotoCapa       String?  @db.VarChar(255)
  acessos        Int      @default(0)
  tipo           String?  @db.VarChar(45)
  dataPublicacao DateTime @default(now()) @db.Timestamp(0)
  usuarioId      Int      @db.UnsignedInt

  usuario     Usuario      @relation(fields: [usuarioId], references: [id])
  curtidas    Curtir[]
  comentarios Comentario[]
}

model Curtir {
  publicacaoId Int      @db.UnsignedInt
  usuarioId    Int      @db.UnsignedInt
  data         DateTime @default(now()) @db.Timestamp(0)

  publicacao Publicacao @relation(fields: [publicacaoId], references: [id])
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])

  @@id([publicacaoId, usuarioId])
}

model Comentario {
  id           Int      @id @default(autoincrement())
  conteudo     String   @db.Text
  data         DateTime @default(now()) @db.Timestamp(0)
  usuarioId    Int      @db.UnsignedInt
  publicacaoId Int      @db.UnsignedInt

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  publicacao Publicacao @relation(fields: [publicacaoId], references: [id])
}

model Seguir {
  seguidorId Int      @db.UnsignedInt
  seguidoId  Int      @db.UnsignedInt
  data       DateTime @default(now()) @db.Timestamp(0)

  seguidor Usuario @relation("Seguidor", fields: [seguidorId], references: [id])
  seguido  Usuario @relation("Seguido", fields: [seguidoId], references: [id])

  @@id([seguidorId, seguidoId])
}

model Newsletter {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  ativo        Boolean  @default(true)
  dataCadastro DateTime @default(now()) @db.Timestamp(0)
}
